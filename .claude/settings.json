{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Task(*)",
      "TodoWrite(*)",
      "NotebookEdit(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/reinject-context.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'OP SpellTable config loaded. Skills: /forge (opus), /init-project (opus), /next-feature (opus), /architect (sonnet), /frontend (sonnet), /backend (sonnet), /ml-engineer (sonnet), /developer (sonnet), /tester (sonnet), /reviewer (sonnet), /stabilizer (sonnet)'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "L'utilisateur a-t-il demandé d'implémenter une feature ou de modifier du code ? Si oui, vérifie que le stabilizer a été mentionné ou que les checks de stabilité (build, tests, lint) ont été exécutés. Si les checks n'ont pas été faits et qu'il y a eu des modifications de code significatives, réponds {\"ok\": false, \"reason\": \"Lance /stabilizer avant de terminer\"}. Si les checks ont été faits ou si la demande ne concernait pas du code, réponds {\"ok\": true}."
          }
        ]
      }
    ]
  }
}

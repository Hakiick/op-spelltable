generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model CardSet {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  releaseDate DateTime?
  cardCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cards       Card[]

  @@index([code])
}

model Room {
  id          String   @id @default(cuid())
  roomCode    String   @unique
  hostPeerId  String?
  guestPeerId String?
  hostUserId  String?
  guestUserId String?
  name        String?
  isPublic    Boolean  @default(false)
  status      String   @default("waiting")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hostUser  User? @relation("HostRooms", fields: [hostUserId], references: [id])
  guestUser User? @relation("GuestRooms", fields: [guestUserId], references: [id])

  @@index([roomCode])
  @@index([status])
  @@index([isPublic])
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  avatarUrl      String?
  gamesPlayed    Int      @default(0)
  gamesWon       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hostedRooms Room[] @relation("HostRooms")
  guestRooms  Room[] @relation("GuestRooms")

  @@index([email])
}

model Card {
  id        String   @id @default(cuid())
  cardId    String   @unique // e.g. "OP01-001"
  name      String
  type      String // Leader, Character, Event, Stage
  color     String // Red, Green, Blue, Purple, Black, Yellow
  cost      Int?
  power     Int?
  counter   Int?
  attribute String?
  effect    String?
  life      Int? // for Leaders
  setCode   String // e.g. "OP01"
  rarity    String // C, UC, R, SR, SEC, L, SP
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  set CardSet @relation(fields: [setCode], references: [code])

  @@index([setCode])
  @@index([name])
  @@index([cost])
  @@index([color])
  @@index([type])
}

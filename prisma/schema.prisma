generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model CardSet {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  releaseDate DateTime?
  cardCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cards       Card[]

  @@index([code])
}

model Room {
  id          String   @id @default(cuid())
  roomCode    String   @unique
  hostPeerId  String?
  guestPeerId String?
  status      String   @default("waiting")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roomCode])
  @@index([status])
}

model Card {
  id        String   @id @default(cuid())
  cardId    String   @unique // e.g. "OP01-001"
  name      String
  type      String // Leader, Character, Event, Stage
  color     String // Red, Green, Blue, Purple, Black, Yellow
  cost      Int?
  power     Int?
  counter   Int?
  attribute String?
  effect    String?
  life      Int? // for Leaders
  setCode   String // e.g. "OP01"
  rarity    String // C, UC, R, SR, SEC, L, SP
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  set CardSet @relation(fields: [setCode], references: [code])

  @@index([setCode])
  @@index([name])
  @@index([cost])
  @@index([color])
  @@index([type])
}
